{
  "name": "beliq/woocommerce-beliq",
  "description": "Generate compliant EN 16931 e-invoices from WooCommerce orders through the beliq API.",
  "type": "wordpress-plugin",
  "license": "MIT",
  "authors": [
    { "name": "beliq", "email": "hello@beliq.eu" }
  ],
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.11",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "Beliq\\WooCommerce\\": "src/",
      "Beliq\\Core\\": "src/Core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Beliq\\WooCommerce\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpcs": "phpcs -q",
    "scrub:check": "! grep -rnP '\\x{2014}' woocommerce-beliq.php src tests languages README.md CHANGELOG.md ROADMAP.md readme.txt"
  }
}
